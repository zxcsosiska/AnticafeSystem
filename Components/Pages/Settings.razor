</style>

@code {
    private List<TariffDto> _tariffs = new();
    private List<RoomDto> _rooms = new();
    private decimal _pricePerMinute = 3.5m;
    private int _minimumMinutes = 30;
    private string _message = string.Empty;
    private bool _isSuccess = false;
    private bool _isSaving = false;
    
    private string _newRoomName = string.Empty;
    private int _newRoomTables = 5;
    private string _roomMessage = string.Empty;
    private bool _roomIsSuccess = false;
    
    private StatsDto _stats = new();

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        await LoadTariffs();
        await LoadRooms();
        await LoadStats();
    }

    private async Task LoadTariffs()
    {
        try
        {
            var response = await Http.GetAsync("api/tariff/current");
            if (response.IsSuccessStatusCode)
            {
                var json = await response.Content.ReadAsStringAsync();
                var doc = JsonDocument.Parse(json);
                var root = doc.RootElement;
                
                if (root.TryGetProperty("currentPricePerMinute", out JsonElement priceElement))
                    _pricePerMinute = priceElement.GetDecimal();
                if (root.TryGetProperty("minimumMinutes", out JsonElement minElement))
                    _minimumMinutes = minElement.GetInt32();
                if (root.TryGetProperty("activeTariffs", out JsonElement tariffsElement))
                    _tariffs = JsonSerializer.Deserialize<List<TariffDto>>(tariffsElement.GetRawText()) ?? new();
            }
        }
        catch { }
    }

    private async Task LoadRooms()
    {
        try
        {
            var response = await Http.GetAsync("api/settings/rooms");
            if (response.IsSuccessStatusCode)
                _rooms = await response.Content.ReadFromJsonAsync<List<RoomDto>>() ?? new();
        }
        catch { }
    }

    private async Task LoadStats()
    {
        try
        {
            var sessions = await Http.GetFromJsonAsync<List<dynamic>>("api/session/active");
            _stats.ActiveSessions = sessions?.Count ?? 0;
            
            var bookings = await Http.GetFromJsonAsync<List<dynamic>>("api/booking/active");
            _stats.Bookings = bookings?.Count ?? 0;
        }
        catch { }
    }

    private async Task SaveSettings()
    {
        _isSaving = true;
        _message = string.Empty;
        
        try
        {
            var priceResponse = await Http.PostAsJsonAsync("api/settings", new 
            { 
                key = "PricePerMinute", 
                value = _pricePerMinute.ToString(System.Globalization.CultureInfo.InvariantCulture) 
            });
            
            if (priceResponse.IsSuccessStatusCode)
            {
                var minResponse = await Http.PostAsJsonAsync("api/settings", new 
                { 
                    key = "MinimumMinutes", 
                    value = _minimumMinutes.ToString() 
                });
                
                if (minResponse.IsSuccessStatusCode)
                {
                    _message = "✅ Настройки успешно сохранены!";
                    _isSuccess = true;
                    await LoadTariffs();
                }
                else
                {
                    _message = "❌ Ошибка сохранения минимальной длительности";
                    _isSuccess = false;
                }
            }
            else
            {
                _message = "❌ Ошибка сохранения цены";
                _isSuccess = false;
            }
        }
        catch (Exception ex)
        {
            _message = $"❌ Ошибка: {ex.Message}";
            _isSuccess = false;
        }
        finally
        {
            _isSaving = false;
            StateHasChanged();
            
            await Task.Delay(5000);
            _message = string.Empty;
            StateHasChanged();
        }
    }

    private async Task AddRoom()
    {
        if (string.IsNullOrWhiteSpace(_newRoomName))
        {
            _roomMessage = "❌ Введите название зала";
            _roomIsSuccess = false;
            return;
        }

        try
        {
            var response = await Http.PostAsJsonAsync("api/settings/rooms", new
            {
                name = _newRoomName.Trim(),
                type = "usual",
                tableCount = _newRoomTables
            });

            var result = await response.Content.ReadFromJsonAsync<dynamic>();
            
            if (response.IsSuccessStatusCode)
            {
                _roomMessage = $"✅ {result?.message ?? "Зал создан"}";
                _roomIsSuccess = true;
                _newRoomName = string.Empty;
                _newRoomTables = 5;
                await LoadRooms();
            }
            else
            {
                _roomMessage = $"❌ {result?.error ?? "Ошибка"}";
                _roomIsSuccess = false;
            }
            
            await Task.Delay(3000);
            _roomMessage = string.Empty;
            StateHasChanged();
        }
        catch (Exception ex)
        {
            _roomMessage = $"❌ Ошибка: {ex.Message}";
            _roomIsSuccess = false;
        }
    }

    private async Task DeleteRoom(int id)
    {
        var confirmed = await JSRuntime.InvokeAsync<bool>("confirm", "Удалить зал и все столы?");
        if (!confirmed) return;
        
        try
        {
            var response = await Http.DeleteAsync($"api/settings/rooms/{id}");
            var result = await response.Content.ReadFromJsonAsync<dynamic>();
            
            if (response.IsSuccessStatusCode)
            {
                _roomMessage = $"✅ {result?.message ?? "Зал удалён"}";
                _roomIsSuccess = true;
                await LoadRooms();
            }
            else
            {
                _roomMessage = $"❌ {result?.error ?? "Ошибка"}";
                _roomIsSuccess = false;
            }
            
            await Task.Delay(3000);
            _roomMessage = string.Empty;
            StateHasChanged();
        }
        catch (Exception ex)
        {
            _roomMessage = $"❌ Ошибка: {ex.Message}";
            _roomIsSuccess = false;
        }
    }

    private class TariffDto
    {
        public int Id { get; set; }
        public string Name { get; set; } = string.Empty;
        public decimal PricePerMinute { get; set; }
        public int? DayOfWeek { get; set; }
        public int HourFrom { get; set; }
        public int HourTo { get; set; }
        public int MinimumMinutes { get; set; }
        public bool IsActive { get; set; }
        public int Priority { get; set; }
    }

    private class RoomDto
    {
        public int Id { get; set; }
        public string Name { get; set; } = string.Empty;
        public bool IsActive { get; set; }
        public int TableCount { get; set; }
    }

    private class StatsDto
    {
        public int ActiveSessions { get; set; }
        public int Bookings { get; set; }
    }
}