@page "/settings"
@using Anticafe.Models
@inject HttpClient Http
@inject IJSRuntime JSRuntime
@using System.Text.Json

<div class="page-container">
    <div class="page-header">
        <h2>⚙️ Настройки системы</h2>
    </div>

    <!-- Тарифы -->
    <div class="card-glass mb-4">
        <div class="card-header-glass">
            <span>💰 Управление тарифами</span>
            <button class="btn-refresh" @onclick="LoadData">🔄</button>
        </div>
        <div class="card-body-glass">
            <div class="settings-grid">
                <div class="form-group-glass">
                    <label>Цена за минуту</label>
                    <div class="input-group-glass">
                        <input @bind="_pricePerMinute" type="number" step="0.5" min="0.5" class="form-control-glass" />
                        <span class="input-group-text-glass">₽</span>
                    </div>
                </div>
                <div class="form-group-glass">
                    <label>Минимальная длительность</label>
                    <div class="input-group-glass">
                        <input @bind="_minimumMinutes" type="number" min="30" step="15" class="form-control-glass" />
                        <span class="input-group-text-glass">мин</span>
                    </div>
                </div>
                <div class="form-group-glass" style="justify-content: flex-end;">
                    <button class="btn-save-glass" @onclick="SaveSettings" disabled="@_isSaving">
                        @(_isSaving ? "⏳ Сохранение..." : "💾 Сохранить настройки")
                    </button>
                </div>
            </div>
            
            @if (!string.IsNullOrEmpty(_message))
            {
                <div class="@(_isSuccess ? "alert-success-glass" : "alert-error-glass") mt-3">
                    @_message
                </div>
            }

            <hr class="divider-glass" />
            
            <div class="table-wrap">
                <table class="table-glass">
                    <thead>
                        <tr>
                            <th>Название</th>
                            <th>Цена</th>
                            <th>Дни</th>
                            <th>Время</th>
                            <th>Мин.</th>
                            <th>Статус</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (_tariffs.Any())
                        {
                            @foreach (var tariff in _tariffs)
                            {
                                <tr>
                                    <td><span class="guest-name">@tariff.Name</span></td>
                                    <td><span class="price-tag">@tariff.PricePerMinute ₽</span></td>
                                    <td>@(tariff.DayOfWeek.HasValue ? ((DayOfWeek)tariff.DayOfWeek).ToString() : "Все дни")</td>
                                    <td>@(tariff.HourFrom == 0 && tariff.HourTo == 0 ? "Круглосуточно" : $"{tariff.HourFrom:00}:00 - {tariff.HourTo:00}:00")</td>
                                    <td>@tariff.MinimumMinutes</td>
                                    <td>
                                        <span class="status-badge @(tariff.IsActive ? "active" : "inactive")">
                                            @(tariff.IsActive ? "✅ Активен" : "❌ Неактивен")
                                        </span>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="6" class="empty-state-glass">Нет активных тарифов</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <!-- Залы -->
    <div class="card-glass mb-4">
        <div class="card-header-glass">
            <span>🏠 Управление залами</span>
        </div>
        <div class="card-body-glass">
            <div class="settings-grid">
                <div class="form-group-glass">
                    <label>Название зала</label>
                    <input @bind="_newRoomName" class="form-control-glass" placeholder="VIP зал" />
                </div>
                <div class="form-group-glass">
                    <label>Количество столов</label>
                    <input @bind="_newRoomTables" type="number" class="form-control-glass" min="1" max="20" />
                </div>
                <div class="form-group-glass" style="justify-content: flex-end;">
                    <button class="btn-add-glass" @onclick="AddRoom">➕ Добавить зал</button>
                </div>
            </div>
            
            @if (!string.IsNullOrEmpty(_roomMessage))
            {
                <div class="@(_roomIsSuccess ? "alert-success-glass" : "alert-error-glass") mt-3">
                    @_roomMessage
                </div>
            }

            <div class="table-wrap">
                <table class="table-glass">
                    <thead>
                        <tr>
                            <th>Название</th>
                            <th>Столов</th>
                            <th>Статус</th>
                            <th>Действие</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var room in _rooms)
                        {
                            <tr>
                                <td><span class="guest-name">@room.Name</span></td>
                                <td>@room.TableCount</td>
                                <td>
                                    <span class="status-badge @(room.IsActive ? "active" : "inactive")">
                                        @(room.IsActive ? "✅ Активен" : "❌ Неактивен")
                                    </span>
                                </td>
                                <td>
                                    @if (room.Id > 1)
                                    {
                                        <button class="btn-delete-glass" @onclick="() => DeleteRoom(room.Id)">
                                            🗑 Удалить
                                        </button>
                                    }
                                    else
                                    {
                                        <span class="text-muted-glass">Основной</span>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <!-- Информация -->
    <div class="card-glass">
        <div class="card-header-glass">
            <span>ℹ️ Информация о системе</span>
        </div>
        <div class="card-body-glass">
            <div class="info-grid">
                <div class="info-item">
                    <span class="info-label">Версия</span>
                    <span class="info-value">1.0.0</span>
                </div>
                <div class="info-item">
                    <span class="info-label">База данных</span>
                    <span class="info-value">SQLite</span>
                </div>
                <div class="info-item">
                    <span class="info-label">Статус</span>
                    <span class="status-badge active">✅ Работает</span>
                </div>
                <div class="info-item">
                    <span class="info-label">Активных сеансов</span>
                    <span class="info-value">@_stats.ActiveSessions</span>
                </div>
                <div class="info-item">
                    <span class="info-label">Бронирований</span>
                    <span class="info-value">@_stats.Bookings</span>
                </div>
                <div class="info-item">
                    <span class="info-label">Всего залов</span>
                    <span class="info-value">@_rooms.Count</span>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
