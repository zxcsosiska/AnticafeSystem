        background: rgba(255,107,122,0.15);
        border: 1px solid rgba(255,107,122,0.2);
        border-radius: 8px;
        color: #ff6b7a;
        font-weight: 600;
        font-size: 0.85rem;
        cursor: pointer;
        transition: all 0.3s ease;
    }

    .btn-end-glass:hover {
