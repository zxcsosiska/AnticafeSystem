    .form-control-glass::placeholder {
        color: rgba(255,255,255,0.3);
    }

    .form-control-glass option {
        background: #1a1a2e;
        color: white;
    }

    .btn-primary-glass {
        padding: 10px 24px;
        background: linear-gradient(135deg, #667eea, #764ba2);
        color: white;
        border: none;
        border-radius: 10px;
        font-weight: 600;
        font-size: 0.95rem;
        cursor: pointer;
        transition: all 0.3s ease;
        box-shadow: 0 4px 20px rgba(102,126,234,0.3);
