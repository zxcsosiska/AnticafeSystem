@page "/sessions"
@using Anticafe.Models
@inject HttpClient Http
@inject IJSRuntime JSRuntime
@inject NavigationManager Navigation

<div class="page-container">
    <div class="page-header">
        <h2>🪑 Управление сеансами</h2>
        <div class="header-actions">
            <span class="badge-active">🟢 @_activeSessions.Count активных</span>
            <button class="btn-refresh" @onclick="LoadData">🔄</button>
        </div>
    </div>

    <!-- Форма создания сеанса -->
    <div class="card-glass mb-4">
        <div class="card-header-glass">
            <span>➕ Новый сеанс</span>
        </div>
        <div class="card-body-glass">
            <div class="form-grid">
                <div class="form-group-glass">
                    <label>Имя гостя *</label>
                    <input @bind="_newGuestName" class="form-control-glass" placeholder="Иван Петров" />
                </div>
                <div class="form-group-glass">
                    <label>Телефон</label>
                    <input @bind="_newPhone" class="form-control-glass" placeholder="+7 999 123-45-67" />
                </div>
                <div class="form-group-glass">
                    <label>Стол *</label>
                    <select @bind="_newTableNumber" class="form-control-glass">
                        @foreach (var table in _tables)
                        {
                            <option value="@table.TableNumber">Стол @table.TableNumber</option>
                        }
                    </select>
                </div>
                <div class="form-group-glass">
                    <label>Длительность *</label>
                    <select @bind="_newDuration" class="form-control-glass">
                        <option value="30">30 мин</option>
                        <option value="60">1 час</option>
                        <option value="90">1.5 часа</option>
                        <option value="120">2 часа</option>
                        <option value="180">3 часа</option>
                        <option value="240">4 часа</option>
                    </select>
                </div>
            </div>
            <button class="btn-primary-glass" @onclick="StartSession" disabled="@_isLoading">
                @(_isLoading ? "⏳ Создание..." : "🚀 Начать сеанс")
            </button>
            
            @if (!string.IsNullOrEmpty(_errorMessage))
            {
                <div class="alert-error-glass">@_errorMessage</div>
            }
            @if (!string.IsNullOrEmpty(_successMessage))
            {
                <div class="alert-success-glass">✅ @_successMessage</div>
            }
        </div>
    </div>

    <!-- Активные сеансы -->
    <div class="card-glass">
        <div class="card-header-glass">
            <span>🟢 Активные сеансы</span>
            <span class="badge-glass">@_activeSessions.Count</span>
        </div>
        <div class="card-body-glass p-0">
            @if (_activeSessions.Count == 0)
            {
                <div class="empty-state-glass">
                    <div class="empty-icon">📭</div>
                    <p>Нет активных сеансов</p>
                    <span class="empty-hint">Создайте новый сеанс выше</span>
                </div>
            }
            else
            {
                <div class="table-wrap">
                    <table class="table-glass">
                        <thead>
                            <tr>
                                <th>Гость</th>
                                <th>Стол</th>
                                <th>Начало</th>
                                <th>Прогресс</th>
                                <th>Стоимость</th>
                                <th>Действие</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var session in _activeSessions)
                            {
                                var elapsed = (DateTime.Now - session.StartTime).TotalMinutes;
                                var progress = Math.Min(100, (elapsed / session.PlannedDurationMinutes) * 100);
                                var isOverdue = progress > 100;
                                
                                <tr>
                                    <td>
                                        <div class="guest-name">@session.GuestName</div>
                                        <div class="guest-phone">@(session.Phone ?? "—")</div>
                                    </td>
                                    <td>Стол @session.TableNumber</td>
                                    <td>@session.StartTime.ToString("HH:mm")</td>
                                    <td>
                                        <div class="progress-glass @(isOverdue ? "overdue" : "")">
                                            <div class="progress-bar-glass" style="width: @Math.Min(100, progress)%">
                                                @((int)elapsed) / @session.PlannedDurationMinutes мин
                                            </div>
                                        </div>
                                    </td>
                                    <td>
                                        <div class="price-tag">@session.TotalCost ₽</div>
                                        <div class="price-rate">@session.TariffRate ₽/мин</div>
                                    </td>
                                    <td>
                                        <button class="btn-end-glass" @onclick="() => EndSession(session.Id)">
                                            ⏹ Завершить
                                        </button>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>

    <!-- Завершенные сеансы -->
    @if (_completedSessions.Any())
    {
        <div class="card-glass mt-4">
            <div class="card-header-glass">
                <span>✅ Завершенные сегодня</span>
                <span class="badge-glass">@_completedSessions.Count</span>
            </div>
            <div class="card-body-glass p-0">
                <div class="table-wrap">
                    <table class="table-glass">
                        <thead>
                            <tr>
                                <th>Гость</th>
                                <th>Стол</th>
                                <th>Длительность</th>
                                <th>Стоимость</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var session in _completedSessions.Take(10))
                            {
                                <tr>
                                    <td>@session.GuestName</td>
                                    <td>Стол @session.TableNumber</td>
                                    <td>@session.DurationMinutes мин</td>
                                    <td><span class="price-tag">@session.TotalCost ₽</span></td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    }
</div>

<style>
    .page-container {
        max-width: 1400px;
        margin: 0 auto;
    }

    .page-header {
        display: flex;
        justify-content: space-between;
