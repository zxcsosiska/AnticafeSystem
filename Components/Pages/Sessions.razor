    .mt-4 { margin-top: 24px; }
    .mb-4 { margin-bottom: 24px; }

    @@media (max-width: 768px) {
        .form-grid {
            grid-template-columns: 1fr;
        }
        .page-header {
            flex-direction: column;
            align-items: flex-start;
            gap: 12px;
        }
        .table-glass {
            font-size: 0.8rem;
        }
        .table-glass thead th,
        .table-glass tbody td {
            padding: 8px 10px;
        }
        .progress-glass {
            width: 100px;
        }
    }
</style>

@code {
    private List<SessionDto> _activeSessions = new();
    private List<SessionDto> _completedSessions = new();
    private List<TableDto> _tables = new();
    private string _newGuestName = "";
    private string _newPhone = "";
    private int _newDuration = 60;
    private int _newTableNumber = 1;
    private string _errorMessage = "";
    private string _successMessage = "";
    private bool _isLoading = false;
    private System.Timers.Timer? _timer;

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
        await LoadTables();
        
        _timer = new System.Timers.Timer(5000);
        _timer.Elapsed += async (s, e) => await InvokeAsync(LoadData);
        _timer.Start();
    }

    private async Task LoadData()
    {
        try
        {
            var active = await Http.GetFromJsonAsync<List<SessionDto>>("api/session/active");
            if (active != null) _activeSessions = active;

            var today = DateTime.Now.ToString("yyyy-MM-dd");
            var detailed = await Http.GetFromJsonAsync<DetailedReport>($"api/report/detailed?from={today}&to={today}");
            if (detailed != null) _completedSessions = detailed.Sessions ?? new();
            
            StateHasChanged();
        }
        catch { }
    }

    private async Task LoadTables()
    {
        try
        {
            var tables = await Http.GetFromJsonAsync<List<TableDto>>("api/session/tables");
            if (tables != null && tables.Any())
            {
                _tables = tables;
                _newTableNumber = _tables.First().TableNumber;
            }
        }
        catch { }
    }

    private async Task StartSession()
    {
        _errorMessage = "";
        _successMessage = "";
        
        if (string.IsNullOrWhiteSpace(_newGuestName))
        {
            _errorMessage = "Введите имя гостя";
            return;
        }

        _isLoading = true;
        try
        {
            var request = new
            {
                guestName = _newGuestName.Trim(),
                phone = string.IsNullOrWhiteSpace(_newPhone) ? null : _newPhone.Trim(),
                tableNumber = _newTableNumber,
                roomId = 1,
                durationMinutes = _newDuration
            };

            var response = await Http.PostAsJsonAsync("api/session/start", request);
            
            if (response.IsSuccessStatusCode)
            {
                _successMessage = $"Сеанс для {_newGuestName} начат! Стол {_newTableNumber}";
                _newGuestName = "";
                _newPhone = "";
                await LoadData();
                
                await Task.Delay(3000);
                _successMessage = "";
            }
            else
            {
                var error = await response.Content.ReadFromJsonAsync<dynamic>();
                _errorMessage = error?.error ?? "Ошибка создания сеанса";
            }
        }
        catch (Exception ex)
        {
            _errorMessage = $"Ошибка: {ex.Message}";
        }
        finally
        {
            _isLoading = false;
            StateHasChanged();
        }
    }

    private async Task EndSession(int id)
    {
        var confirmed = await JSRuntime.InvokeAsync<bool>("confirm", "Завершить сеанс?");
        if (!confirmed) return;
        
        try
        {
            var response = await Http.PostAsync($"api/session/end/{id}", null);
            if (response.IsSuccessStatusCode)
            {
                var result = await response.Content.ReadFromJsonAsync<EndSessionResult>();
                await LoadData();
                
                if (result != null)
                {
                    await JSRuntime.InvokeVoidAsync("alert", 
                        $"✅ Сеанс завершен!\n" +
                        $"Гость: {result.GuestName}\n" +
                        $"Длительность: {result.ActualDurationMinutes} мин\n" +
                        $"Сумма: {result.TotalCost} ₽\n" +
                        $"{result.Message}");
                }
            }
        }
        catch (Exception ex)
        {
            await JSRuntime.InvokeVoidAsync("alert", $"Ошибка: {ex.Message}");
        }
    }

    public void Dispose() => _timer?.Dispose();

    private class SessionDto
    {
        public int Id { get; set; }
        public string GuestName { get; set; } = "";
        public string? Phone { get; set; }
        public int TableNumber { get; set; }
        public DateTime StartTime { get; set; }
        public int PlannedDurationMinutes { get; set; }
        public int DurationMinutes { get; set; }
        public decimal TariffRate { get; set; }
        public decimal TotalCost { get; set; }
        public bool IsActive { get; set; }
    }

    private class TableDto
    {
        public int Id { get; set; }
        public int TableNumber { get; set; }
        public int RoomId { get; set; }
    }

    private class DetailedReport
    {
        public int Total { get; set; }
        public List<SessionDto> Sessions { get; set; } = new();
        public decimal TotalRevenue { get; set; }
        public int TotalMinutes { get; set; }
    }

    private class EndSessionResult
    {
        public int Id { get; set; }
        public string GuestName { get; set; } = "";
        public int ActualDurationMinutes { get; set; }
        public decimal TotalCost { get; set; }
        public string Message { get; set; } = "";
    }
}