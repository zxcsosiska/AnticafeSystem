        color: rgba(255,255,255,0.4);
        font-weight: 600;
        font-size: 0.75rem;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        border-bottom: 1px solid rgba(255,255,255,0.05);
    }

    .table-glass tbody td {
        padding: 12px 16px;
        border-bottom: 1px solid rgba(255,255,255,0.03);
