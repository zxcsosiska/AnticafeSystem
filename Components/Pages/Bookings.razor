@page "/bookings"
@using Anticafe.Models
@using System.Text.RegularExpressions
@inject HttpClient Http
@inject IJSRuntime JSRuntime

<div class="page-container">
    <div class="page-header">
        <h2>📅 Бронирования</h2>
        <div class="header-actions">
            <span class="badge-active">📋 @_activeBookings.Count активных</span>
            <button class="btn-refresh" @onclick="LoadBookings">🔄</button>
        </div>
    </div>

    <!-- Форма создания бронирования -->
    <div class="card-glass mb-4">
        <div class="card-header-glass">
            <span>📝 Новое бронирование</span>
        </div>
        <div class="card-body-glass">
            <div class="form-grid">
                <div class="form-group-glass">
                    <label>Имя гостя *</label>
                    <input @bind="_newBookingGuest" class="form-control-glass" placeholder="Иван Петров" />
                </div>
                <div class="form-group-glass">
                    <label>Телефон</label>
                    <input @bind="_newBookingPhone" 
                           class="form-control-glass @(!string.IsNullOrEmpty(_phoneError) ? "error" : "")" 
                           placeholder="+7 999 123-45-67" 
                           @oninput="ValidatePhone" />
                    @if (!string.IsNullOrEmpty(_phoneError))
                    {
                        <small class="text-danger-glass">@_phoneError</small>
                    }
                    <small class="text-hint-glass">Необязательное поле</small>
                </div>
                <div class="form-group-glass">
                    <label>Дата *</label>
                    <input type="date" @bind="_newBookingDate" class="form-control-glass" />
                </div>
                <div class="form-group-glass">
                    <label>Время *</label>
                    <input type="time" @bind="_newBookingTime" class="form-control-glass" />
                </div>
                <div class="form-group-glass">
                    <label>Длительность *</label>
                    <div class="input-group-glass">
                        <input type="number" @bind="_newBookingDuration" class="form-control-glass" min="30" step="15" />
                        <span class="input-group-text-glass">мин</span>
                    </div>
                    @if (_newBookingDuration < 30)
                    {
                        <small class="text-danger-glass">Минимум 30 минут</small>
                    }
                </div>
                <div class="form-group-glass">
                    <label>Стол *</label>
                    <select @bind="_newBookingTable" class="form-control-glass">
                        @foreach (var table in _availableTables)
                        {
                            <option value="@table.TableNumber">Стол @table.TableNumber</option>
                        }
                    </select>
                </div>
            </div>
            
            <!-- ИСПРАВЛЕННАЯ КНОПКА -->
            <button class="btn-primary-glass" @onclick="CreateBooking" 
                    disabled="@(_isBookingLoading || _newBookingDuration < 30 || string.IsNullOrWhiteSpace(_newBookingGuest) || (_hasPhoneError && !string.IsNullOrWhiteSpace(_newBookingPhone)))">
                @(_isBookingLoading ? "⏳ Создание..." : "📅 Забронировать")
            </button>
            
            @if (!string.IsNullOrEmpty(_bookingError))
            {
                <div class="alert-error-glass mt-3">@_bookingError</div>
            }
            @if (!string.IsNullOrEmpty(_bookingSuccess))
            {
                <div class="alert-success-glass mt-3">✅ @_bookingSuccess</div>
            }
        </div>
    </div>

    <!-- Активные бронирования -->
    <div class="card-glass">
        <div class="card-header-glass">
            <span>📋 Активные бронирования</span>
            <span class="badge-glass">@_activeBookings.Count</span>
        </div>
        <div class="card-body-glass p-0">
            @if (_activeBookings.Count == 0)
            {
                <div class="empty-state-glass">
                    <div class="empty-icon">📭</div>
                    <p>Нет активных бронирований</p>
                    <span class="empty-hint">Создайте новое бронирование выше</span>
                </div>
            }
            else
            {
                <div class="table-wrap">
                    <table class="table-glass">
                        <thead>
                            <tr>
                                <th>Гость</th>
                                <th>Телефон</th>
                                <th>Стол</th>
                                <th>Дата</th>
                                <th>Время</th>
                                <th>Длительность</th>
                                <th>Действие</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var booking in _activeBookings)
                            {
                                <tr>
                                    <td>
                                        <div class="guest-name">@booking.GuestName</div>
                                    </td>
                                    <td>@booking.Phone</td>
                                    <td>Стол @booking.TableNumber</td>
                                    <td>@booking.BookingDate.ToString("dd.MM.yyyy")</td>
                                    <td>@booking.StartTime</td>
                                    <td>@booking.DurationMinutes мин</td>
                                    <td>
                                        <button class="btn-cancel-glass" @onclick="() => CancelBooking(booking.Id)">
                                            ❌ Отменить
                                        </button>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
</div>

<style>
