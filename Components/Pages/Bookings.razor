</style>

@code {
    private List<BookingDto> _activeBookings = new();
    private List<TableDto> _bookingTables = new();
    private List<TableDto> _availableTables = new();
    
    private string _newBookingGuest = string.Empty;
    private string _newBookingPhone = string.Empty;
    private DateTime _newBookingDate = DateTime.Now.Date;
    private TimeOnly _newBookingTime = new TimeOnly(19, 0, 0);
    private int _newBookingDuration = 60;
    private int _newBookingTable = 1;
    private string _bookingError = string.Empty;
    private string _bookingSuccess = string.Empty;
    private bool _isBookingLoading = false;
    private string _phoneError = string.Empty;
    private bool _hasPhoneError = false;

    protected override async Task OnInitializedAsync()
    {
        await LoadBookings();
        await LoadTables();
        
        var now = DateTime.Now;
        var nextHour = now.Hour + 1;
        if (nextHour >= 24) nextHour = 0;
        _newBookingTime = new TimeOnly(nextHour, 0, 0);
    }

    private async Task LoadBookings()
    {
        try
        {
            var bookings = await Http.GetFromJsonAsync<List<BookingDto>>("api/booking/active");
            if (bookings != null)
            {
                _activeBookings = bookings;
                UpdateAvailableTables();
            }
        }
        catch { }
    }

    private async Task LoadTables()
    {
        try
        {
            var tables = await Http.GetFromJsonAsync<List<TableDto>>("api/session/tables");
            if (tables != null && tables.Any())
            {
                _bookingTables = tables;
                _availableTables = tables;
                _newBookingTable = _bookingTables.First().TableNumber;
            }
        }
        catch { }
    }

    private void UpdateAvailableTables()
    {
        var bookedTableNumbers = _activeBookings.Select(b => b.TableNumber).ToList();
        
        _availableTables = _bookingTables
            .Where(t => !bookedTableNumbers.Contains(t.TableNumber))
            .ToList();

        if (!_availableTables.Any(t => t.TableNumber == _newBookingTable) && _availableTables.Any())
        {
            _newBookingTable = _availableTables.First().TableNumber;
        }
        StateHasChanged();
    }

    private void ValidatePhone()
    {
        // Если поле пустое - это допустимо (необязательное поле)
        if (string.IsNullOrWhiteSpace(_newBookingPhone))
        {
            _phoneError = string.Empty;
            _hasPhoneError = false;
            return;
        }
        
        // Удаляем все пробелы, скобки, дефисы
        var cleaned = Regex.Replace(_newBookingPhone, @"[\s\-\(\)]", "");
        
        // Проверяем, что остались только цифры и + в начале
        if (!Regex.IsMatch(cleaned, @"^\+?[\d]+$"))
        {
            _phoneError = "Телефон должен содержать только цифры и +";
            _hasPhoneError = true;
            return;
        }
        
        // Проверяем длину (без +)
        var digits = cleaned.Replace("+", "");
        if (digits.Length < 10 || digits.Length > 15)
        {
            _phoneError = "Введите корректный номер (10-15 цифр)";
            _hasPhoneError = true;
            return;
        }
        
        // Проверяем, что номер не состоит из одинаковых цифр
        if (digits.Distinct().Count() == 1)
        {
            _phoneError = "Введите корректный номер телефона";
            _hasPhoneError = true;
            return;
        }
        
        // Проверяем, что не просто последовательность 1234567890
        if (digits == "1234567890" || digits == "0123456789")
        {
            _phoneError = "Введите корректный номер телефона";
            _hasPhoneError = true;
            return;
        }
        
        _phoneError = string.Empty;
        _hasPhoneError = false;
    }

    private async Task CreateBooking()
    {
        _bookingError = string.Empty;
        _bookingSuccess = string.Empty;
        
        if (string.IsNullOrWhiteSpace(_newBookingGuest))
        {
            _bookingError = "Введите имя гостя";
            return;
        }
        
        // Если телефон указан, проверяем его
        if (!string.IsNullOrWhiteSpace(_newBookingPhone) && _hasPhoneError)
        {
            _bookingError = "Исправьте ошибки в телефоне";
            return;
        }
        
        if (_newBookingDuration < 30)
        {
            _bookingError = "Минимальная длительность - 30 минут";
            return;
        }

        _isBookingLoading = true;
        try
        {
            var request = new
            {
                guestName = _newBookingGuest.Trim(),
                phone = string.IsNullOrWhiteSpace(_newBookingPhone) ? "Не указан" : _newBookingPhone.Trim(),
                tableNumber = _newBookingTable,
                roomId = 1,
                bookingDate = _newBookingDate.ToString("yyyy-MM-dd"),
                startTime = _newBookingTime.ToString("HH:mm"),
                durationMinutes = _newBookingDuration
            };

            var response = await Http.PostAsJsonAsync("api/booking/create", request);
            
            if (response.IsSuccessStatusCode)
            {
                _bookingSuccess = $"Бронирование для {_newBookingGuest} создано! Стол {_newBookingTable} на {_newBookingDuration} минут";
                _newBookingGuest = string.Empty;
                _newBookingPhone = string.Empty;
                _phoneError = string.Empty;
                _hasPhoneError = false;
                await LoadBookings();
                
                await Task.Delay(3000);
                _bookingSuccess = string.Empty;
            }
            else
            {
                var error = await response.Content.ReadFromJsonAsync<dynamic>();
                _bookingError = error?.error ?? "Ошибка создания бронирования";
            }
        }
        catch (Exception ex)
        {
            _bookingError = $"Ошибка: {ex.Message}";
        }
        finally
        {
            _isBookingLoading = false;
        }
    }

    private async Task CancelBooking(int id)
    {
        var confirmed = await JSRuntime.InvokeAsync<bool>("confirm", "Отменить бронирование?");
        if (!confirmed) return;
        
        try
        {
            var response = await Http.DeleteAsync($"api/booking/cancel/{id}");
            if (response.IsSuccessStatusCode)
            {
                await LoadBookings();
                await JSRuntime.InvokeVoidAsync("alert", "✅ Бронирование отменено");
            }
        }
        catch (Exception ex)
        {
            await JSRuntime.InvokeVoidAsync("alert", $"Ошибка: {ex.Message}");
        }
    }

    private class BookingDto
    {
        public int Id { get; set; }
        public string GuestName { get; set; } = string.Empty;
        public string Phone { get; set; } = string.Empty;
        public int TableNumber { get; set; }
        public DateTime BookingDate { get; set; }
        public string StartTime { get; set; } = string.Empty;
        public int DurationMinutes { get; set; }
    }

    private class TableDto
    {
        public int Id { get; set; }
        public int TableNumber { get; set; }
        public int RoomId { get; set; }
    }
}