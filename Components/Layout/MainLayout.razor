@inherits LayoutComponentBase
@using Microsoft.JSInterop
@inject NavigationManager Navigation
@inject IJSRuntime JSRuntime
@inject HttpClient Http

@if (_isAuthenticated)
{
    <div class="app-layout">
        <aside class="sidebar">
            <div class="sidebar-brand">
                <span class="brand-icon">🍵</span>
                <span class="brand-name">Анти-кафе</span>
            </div>
            
            <nav class="sidebar-nav">
                <a href="/dashboard" class="nav-link @(IsActive("/dashboard") ? "active" : "")">
                    <span>📊</span> Панель
                </a>
                <a href="/sessions" class="nav-link @(IsActive("/sessions") ? "active" : "")">
                    <span>🪑</span> Сеансы
                </a>
                <a href="/bookings" class="nav-link @(IsActive("/bookings") ? "active" : "")">
                    <span>📅</span> Бронирования
                </a>
                <a href="/settings" class="nav-link @(IsActive("/settings") ? "active" : "")">
                    <span>⚙️</span> Настройки
                </a>
            </nav>
            
            <div class="sidebar-footer">
                <div class="user-info">
                    <span class="avatar">👤</span>
                    <span class="name">@_userName</span>
                </div>
                <button class="btn-logout" @onclick="Logout">Выйти</button>
            </div>
        </aside>
        
        <main class="main-content">
            <header class="topbar">
                <h2>@GetPageTitle()</h2>
                <div class="topbar-right">
                    <span class="time">@_currentTime</span>
                </div>
            </header>
            
            <div class="content">
                @Body
            </div>
        </main>
    </div>
}
else
{
    <Login />
}

<style>
    html, body {
        background: #0a0a1a !important;
        color: #ffffff !important;
        margin: 0;
        padding: 0;
        min-height: 100vh;
    }
    
    .app-layout {
        display: flex;
        min-height: 100vh;
        background: #0a0a1a;
    }
    
    .sidebar {
        width: 260px;
        min-height: 100vh;
        background: rgba(255,255,255,0.03);
        backdrop-filter: blur(20px);
        border-right: 1px solid rgba(255,255,255,0.05);
        display: flex;
        flex-direction: column;
        position: fixed;
        top: 0;
        left: 0;
        bottom: 0;
        z-index: 100;
        padding: 24px 16px;
    }
    
    .sidebar-brand {
        display: flex;
        align-items: center;
        gap: 12px;
        padding: 0 12px 24px 12px;
        border-bottom: 1px solid rgba(255,255,255,0.05);
        margin-bottom: 20px;
    }
    
    .sidebar-brand .brand-icon { font-size: 2rem; }
    .sidebar-brand .brand-name { font-size: 1.2rem; font-weight: 700; color: white; }
    
    .sidebar-nav {
        flex: 1;
        display: flex;
        flex-direction: column;
        gap: 4px;
    }
    
    .nav-link {
        display: flex;
        align-items: center;
        gap: 12px;
        padding: 12px 16px;
        border-radius: 10px;
        color: rgba(255,255,255,0.5);
        text-decoration: none;
        transition: all 0.3s ease;
        font-size: 0.95rem;
        font-weight: 500;
    }
    
    .nav-link:hover {
        background: rgba(255,255,255,0.05);
        color: white;
    }
    
    .nav-link.active {
        background: linear-gradient(135deg, rgba(102,126,234,0.2), rgba(118,75,162,0.2));
        color: white;
        border: 1px solid rgba(102,126,234,0.2);
    }
    
    .nav-link span:first-child { font-size: 1.2rem; width: 24px; text-align: center; }
    
    .sidebar-footer {
        border-top: 1px solid rgba(255,255,255,0.05);
        padding-top: 16px;
    }
    
    .user-info {
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 8px 12px;
        border-radius: 10px;
        background: rgba(255,255,255,0.03);
        margin-bottom: 10px;
    }
    
    .user-info .avatar { font-size: 1.4rem; }
    .user-info .name { color: white; font-weight: 500; font-size: 0.9rem; }
    
    .btn-logout {
        width: 100%;
        padding: 10px;
        background: rgba(255,107,122,0.1);
        border: 1px solid rgba(255,107,122,0.15);
        border-radius: 10px;
        color: #ff6b7a;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.3s ease;
        font-size: 0.9rem;
    }
    
    .btn-logout:hover {
        background: rgba(255,107,122,0.2);
        transform: translateY(-1px);
    }
    
    .main-content {
        margin-left: 260px;
        flex: 1;
        padding: 0;
    }
    
    .topbar {
        display: flex;
        justify-content: flex-start; /* ИЗМЕНЕНО: выравнивание по левому краю */
        align-items: center;
        padding: 20px 32px;
        background: rgba(255,255,255,0.02);
        border-bottom: 1px solid rgba(255,255,255,0.04);
        position: sticky;
        top: 0;
        z-index: 50;
        backdrop-filter: blur(10px);
        gap: 20px; /* Расстояние между заголовком и временем */
    }
    
    .topbar h2 {
        font-size: 1.2rem;
        font-weight: 600;
        color: white;
        margin: 0;
        padding-left: 0; /* Убираем лишние отступы */
    }
    
    .topbar-right {
        display: flex;
        align-items: center;
        gap: 16px;
        margin-left: auto; /* Время прижимаем вправо */
    }
    
    .topbar-right .time {
        color: rgba(255,255,255,0.4);
        font-size: 0.9rem;
    }
    
    .content {
        padding: 28px 32px;
        animation: fadeIn 0.4s ease;
    }
    
    @@keyframes fadeIn {
        from { opacity: 0; transform: translateY(12px); }
        to { opacity: 1; transform: translateY(0); }
    }
    
    @@media (max-width: 768px) {
        .sidebar {
            width: 220px;
            transform: translateX(-100%);
        }
        
        .main-content { margin-left: 0; }
        .topbar { padding: 16px; }
        .content { padding: 16px; }
        
        .topbar {
            flex-wrap: wrap;
            gap: 8px;
        }
        
        .topbar h2 {
            font-size: 1rem;
            width: 100%;
        }
        
        .topbar-right {
            margin-left: 0;
            width: 100%;
            justify-content: flex-end;
        }
    }
</style>

@code {
    private bool _isAuthenticated = false;
    private string _userName = "Администратор";
    private string _currentTime = DateTime.Now.ToString("HH:mm");
    private System.Timers.Timer? _timer;

    protected override async Task OnInitializedAsync()
    {
        await CheckAuth();
        
        _timer = new System.Timers.Timer(1000);
        _timer.Elapsed += (s, e) =>
        {
            _currentTime = DateTime.Now.ToString("HH:mm");
            InvokeAsync(StateHasChanged);
        };
        _timer.Start();
    }

    private async Task CheckAuth()
    {
        try
        {
            var token = await JSRuntime.InvokeAsync<string>("localStorage.getItem", "auth_token");
            _isAuthenticated = !string.IsNullOrEmpty(token);

            if (_isAuthenticated)
            {
                Http.DefaultRequestHeaders.Authorization = 
                    new System.Net.Http.Headers.AuthenticationHeaderValue("Bearer", token);
                
                var name = await JSRuntime.InvokeAsync<string>("localStorage.getItem", "user_name");
                if (!string.IsNullOrEmpty(name)) _userName = name;
            }
            
            StateHasChanged();
        }
        catch
        {
            _isAuthenticated = false;
        }
    }

    private bool IsActive(string path) => Navigation.Uri.Contains(path);

    private string GetPageTitle()
    {
        var path = Navigation.Uri;
        if (path.Contains("/dashboard")) return "📊 Панель управления";
        if (path.Contains("/sessions")) return "🪑 Управление сеансами";
        if (path.Contains("/bookings")) return "📅 Бронирования";
        if (path.Contains("/settings")) return "⚙️ Настройки системы";
        return "🍵 Анти-кафе";
    }

    private async Task Logout()
    {
        await JSRuntime.InvokeVoidAsync("localStorage.removeItem", "auth_token");
        await JSRuntime.InvokeVoidAsync("localStorage.removeItem", "user_name");
        await JSRuntime.InvokeVoidAsync("localStorage.removeItem", "user_role");
        Http.DefaultRequestHeaders.Authorization = null;
        _isAuthenticated = false;
        Navigation.NavigateTo("/login", true);
    }
}